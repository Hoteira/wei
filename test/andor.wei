let a uint(3) = 7
let b uint(3) = 5

par main:
    if a > 0 && b > 0:
        print(1)
    if a == 0 || b == 5:
        print(2)
    if a > 10 && b > 10:
        print(9)
    else:
        print(3)
    if a == 7 && b == 5 && a > b:
        print(4)
    if a == 0 || b == 0 || a == b:
        print(9)
    else:
        print(5)

main()
